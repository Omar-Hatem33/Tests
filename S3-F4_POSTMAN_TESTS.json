            "url": {
              "raw": "{{base_url}}/api/rides/1/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "1", "complete"]
            },
            "description": "Attempt to complete ride with stale location data (>5 min old). Should return 400 Bad Request."
          },
          "response": [
            {
              "name": "Failure Response - No Recent Location",
              "originalRequest": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/rides/1/complete",
                  "host": ["{{base_url}}"],
                  "path": ["api", "rides", "1", "complete"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Driver not actively tracked (no recent location ping within 5 minutes)\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario E: Cancel Ride (S3-F7)",
      "item": [
        {
          "name": "E1: Create Ride (ID=2, REQUESTED)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
