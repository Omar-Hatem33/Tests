            },
            "description": "Update driver status to OFFLINE to simulate pre-check failure"
          }
        },
        {
          "name": "C3: Attempt Complete Ride (Pre-Check Fails: Driver Not BUSY)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rides/1/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "1", "complete"]
            },
            "description": "Attempt to complete ride with driver NOT in BUSY status. Should return 400 Bad Request."
          },
          "response": [
            {
              "name": "Failure Response - Driver Not BUSY",
              "originalRequest": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/rides/1/complete",
                  "host": ["{{base_url}}"],
                  "path": ["api", "rides", "1", "complete"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Driver must be BUSY (actively assigned). Current status: OFFLINE\"\n}"
            }
          ]
        }
      ]
    },
