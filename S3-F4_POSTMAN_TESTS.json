            },
            "url": {
              "raw": "{{base_url}}/api/locations/5",
              "host": ["{{base_url}}"],
              "path": ["api", "locations", "5"]
            },
            "description": "Update driver's GPS location to be older than 5 minutes to simulate pre-check failure"
          }
        },
        {
          "name": "D3: Attempt Complete Ride (Pre-Check Fails: No Recent Location)",
          "request": {
            "method": "PUT",
