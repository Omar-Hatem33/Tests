{
  "info": {
    "name": "S3-F4 Complete Ride - Saga Trigger Tests",
    "description": "Postman collection for testing S3-F4 (Complete Ride) M3 refactored saga implementation. Tests all scenarios: happy path, pre-check failures, and cancellation.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Setup Data",
      "item": [
        {
          "name": "Create User (ID=10, ACTIVE)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 10,\n  \"name\": \"Test User\",\n  \"email\": \"testuser@example.com\",\n  \"status\": \"ACTIVE\",\n  \"phone\": \"+1234567890\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users",
              "host": ["{{base_url}}"],
              "path": ["api", "users"]
            },
            "description": "Create a test user with ACTIVE status for S3-F4 pre-check validation"
          }
        },
        {
          "name": "Create Driver (ID=5, BUSY)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 5,\n  \"name\": \"Test Driver\",\n  \"email\": \"driver@example.com\",\n  \"status\": \"BUSY\",\n  \"licenseNumber\": \"DL123456\",\n  \"vehicleDetails\": {\"make\": \"Toyota\", \"model\": \"Prius\", \"vehicleType\": \"ECO\"}\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/drivers",
              "host": ["{{base_url}}"],
              "path": ["api", "drivers"]
            },
            "description": "Create a test driver with BUSY status (actively assigned to a ride)"
          }
        },
        {
          "name": "Create Location for Driver (ID=5, Recent)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"driverId\": 5,\n  \"rideId\": 1,\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"timestamp\": \"2024-05-16T10:00:00Z\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/locations",
              "host": ["{{base_url}}"],
              "path": ["api", "locations"]
            },
            "description": "Create a recent GPS location for the driver (within 5 minutes)"
          }
        },
        {
          "name": "Create Ride (ID=1, IN_PROGRESS)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": 1,\n  \"userId\": 10,\n  \"driverId\": 5,\n  \"pickupLatitude\": 40.7128,\n  \"pickupLongitude\": -74.0060,\n  \"dropoffLatitude\": 40.7580,\n  \"dropoffLongitude\": -73.9855,\n  \"status\": \"IN_PROGRESS\",\n  \"requestedAt\": \"2024-05-16T09:00:00Z\",\n  \"fare\": null\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/rides",
              "host": ["{{base_url}}"],
              "path": ["api", "rides"]
            },
            "description": "Create a ride in IN_PROGRESS status (ready for completion)"
          }
        }
      ]
    },
    {
      "name": "Scenario A: Happy Path - Complete Ride Successfully",
      "item": [
        {
          "name": "A1: Complete Ride (All Pre-Checks Pass)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rides/1/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "1", "complete"]
            },
            "description": "Complete ride with all pre-checks passing. Should return 200 with ride status=COMPLETED and ride.completed event published."
          },
          "response": [
            {
              "name": "Success Response",
              "originalRequest": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/rides/1/complete",
                  "host": ["{{base_url}}"],
                  "path": ["api", "rides", "1", "complete"]
                }
              },
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"userId\": 10,\n  \"driverId\": 5,\n  \"pickupLatitude\": 40.7128,\n  \"pickupLongitude\": -74.0060,\n  \"dropoffLatitude\": 40.7580,\n  \"dropoffLongitude\": -73.9855,\n  \"status\": \"COMPLETED\",\n  \"fare\": 25.50,\n  \"requestedAt\": \"2024-05-16T09:00:00Z\",\n  \"completedAt\": \"2024-05-16T10:30:00Z\"\n}"
            }
          ]
        },
        {
          "name": "A2: Verify Ride Status is COMPLETED",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rides/1",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "1"]
            },
            "description": "Verify the ride status is COMPLETED after the completeRide call"
          }
        },
        {
          "name": "A3: Verify Ride Event Published (Check RabbitMQ)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rides/events?type=ride.completed&rideId=1",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "events"]
            },
            "description": "Query ride events to verify ride.completed was published (implementation-specific endpoint)"
          }
        }
      ]
    },
    {
      "name": "Scenario B: Pre-Check Failure - User DEACTIVATED",
      "item": [
        {
          "name": "B1: Update User to DEACTIVATED",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"DEACTIVATED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/users/10",
              "host": ["{{base_url}}"],
              "path": ["api", "users", "10"]
            },
            "description": "Update user status to DEACTIVATED to simulate pre-check failure"
          }
        },
        {
          "name": "B2: Attempt Complete Ride (Pre-Check Fails: User DEACTIVATED)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rides/1/complete",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "1", "complete"]
            },
            "description": "Attempt to complete ride with DEACTIVATED user. Should return 400 Bad Request and NOT publish event."
          },
          "response": [
            {
              "name": "Failure Response - User DEACTIVATED",
              "originalRequest": {
                "method": "PUT",
                "header": [
                  {
                    "key": "Authorization",
                    "value": "Bearer {{jwt_token}}"
                  }
                ],
                "url": {
                  "raw": "{{base_url}}/api/rides/1/complete",
                  "host": ["{{base_url}}"],
                  "path": ["api", "rides", "1", "complete"]
                }
              },
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"User must be ACTIVE to complete a ride. Current status: DEACTIVATED\"\n}"
            }
          ]
        },
        {
          "name": "B3: Verify Ride Status Still IN_PROGRESS",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/rides/1",
              "host": ["{{base_url}}"],
              "path": ["api", "rides", "1"]
            },
            "description": "Verify the ride status remains IN_PROGRESS after failed pre-check"
          }
        }
      ]
    },
    {
      "name": "Scenario C: Pre-Check Failure - Driver Not BUSY",
