Content-Type: application/json
Authorization: Bearer {{riderToken}}
X-User-Id: 2
X-User-Role: RIDER

{
  "method": "BITCOIN"
}

> {%
    client.log("F4-3 response: " + JSON.stringify(response.body));
    client.test("Status is 400", function() {
        client.assert(response.status === 400,
            "Expected 400, got " + response.status);
    });
%}

###

### [F4-4] RIDE NOT FOUND — Feign returns 404
### Expected: 404
POST http://localhost:8085/api/payments/ride/999
Content-Type: application/json
Authorization: Bearer {{riderToken}}
X-User-Id: 2
X-User-Role: RIDER

{
  "method": "CREDIT_CARD",
  "cardLastFour": "4242"
}

> {%
    client.log("F4-4 response: " + JSON.stringify(response.body));
    client.test("Status is 404", function() {
        client.assert(response.status === 404,
            "Expected 404, got " + response.status);
    });
%}
