### [M2-1] Refund with surge adjustment
POST http://localhost:8085/api/payments/{{testPaymentId}}/refund-surge-adjusted
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-User-Id: 1
X-User-Role: ADMIN

{
  "reason": "customer_request",
  "refundSurge": true
}

> {%
    client.log("M2-1 response: " + JSON.stringify(response.body));
    client.test("Status is 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status);
    });
    client.test("Status is REFUNDED", function() {
        client.assert(response.body.status === "REFUNDED",
            "Expected REFUNDED, got " + response.body.status);
    });
%}

###

### [M1-6] GET /api/payments/user/{userId}/total — new M3 endpoint
### Only needs payment-service, no Feign calls
GET http://localhost:8085/api/payments/user/2/total?startDate=2026-01-01&endDate=2026-12-31
Authorization: Bearer {{adminToken}}
X-User-Id: 1
X-User-Role: ADMIN

> {%
    client.log("Total response: " + JSON.stringify(response.body));
    client.test("Status is 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status);
    });
    client.test("Returns a number", function() {
        client.assert(typeof response.body === "number" || response.body >= 0,
            "Expected numeric total, got: " + response.body);
    });
    client.test("Total is 275", function() {
        client.assert(response.body === 275.0,
            "Expected 275.0, got " + response.body);
    });
%}