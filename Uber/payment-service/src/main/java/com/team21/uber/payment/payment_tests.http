### ─────────────────────────────────────────────────────────────
### M1/M2 PAYMENT ENDPOINTS — no dependencies, always testable
### ─────────────────────────────────────────────────────────────

### [M1-1] Create payment
POST http://localhost:8085/api/payments
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-User-Id: 1
X-User-Role: ADMIN

{
  "rideId": 100,
  "userId": 1,
  "amount": 250.0,
  "status": "PENDING",
  "method": "CREDIT_CARD"
}

> {%
    client.global.set("testPaymentId", response.body.id);
    client.log("Created payment: " + response.body.id);
    client.test("Status is 201", function() {
        client.assert(response.status === 201,
            "Expected 201, got " + response.status);
    });
%}

###

### [M1-2] Get payment by ID
GET http://localhost:8085/api/payments/{{testPaymentId}}
Authorization: Bearer {{adminToken}}
X-User-Id: 1
X-User-Role: ADMIN

> {%
    client.log("M1-2 response: " + JSON.stringify(response.body));
    client.test("Status is 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status);
    });
    client.test("Amount is correct", function() {
        client.assert(response.body.amount === 250.0,
            "Expected 250, got " + response.body.amount);
    });
%}

###

### [M1-3] Update payment
PUT http://localhost:8085/api/payments/{{testPaymentId}}
Content-Type: application/json
Authorization: Bearer {{adminToken}}
X-User-Id: 1
X-User-Role: ADMIN

{
  "amount": 300.0,
  "status": "COMPLETED"
}

> {%
    client.log("M1-3 response: " + JSON.stringify(response.body));
    client.test("Status is 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status);
    });
    client.test("Amount updated", function() {
        client.assert(response.body.amount === 300.0,
            "Expected 300, got " + response.body.amount);
    });
%}

###

### [M1-4] Search payments by status
GET http://localhost:8085/api/payments/search?status=COMPLETED
Authorization: Bearer {{adminToken}}
X-User-Id: 1
X-User-Role: ADMIN

> {%
    client.log("M1-4 count: " + response.body.length);
    client.test("Status is 200", function() {
        client.assert(response.status === 200,
            "Expected 200, got " + response.status);
    });
    client.test("Returns array", function() {
        client.assert(Array.isArray(response.body),
            "Expected array");
    });
%}

