GET http://localhost:8081/api/users/2
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbkBleGFtcGxlLmNvbSIsInVpZCI6MSwicm9sZSI6IkFETUlOIiwiaWF0IjoxNzc4OTUyNjI2LCJleHAiOjE3NzkwMzkwMjZ9.mho1hJSzkuNW_7lNVOCy09fZ9AWO7mzyY9qVt3JYCvk

