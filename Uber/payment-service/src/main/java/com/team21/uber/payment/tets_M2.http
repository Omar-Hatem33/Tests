### Test (a): Valid April range - expect 200 with breakdown
### Expected: CREDIT_CARD (success=2, failure=1, rate=0.667, total=250)
###           CASH        (success=1, failure=0, rate=1.0,   total=75)
###           WALLET      (success=0, failure=1, rate=0.0,   total=0)
GET http://localhost:8085/api/payments/analytics/methods?startDate=2026-04-01&endDate=2026-04-30
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbkBleGFtcGxlLmNvbSIsInVpZCI6MSwicm9sZSI6IkFETUlOIiwiaWF0IjoxNzc3OTgyMDI3LCJleHAiOjE3NzgwNjg0Mjd9.Brvd6EoneYmDnggns-cGqfpkZcjXSwMDOSFnpl9jaxc

