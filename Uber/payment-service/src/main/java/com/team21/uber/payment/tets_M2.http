###############################################
### PRE-REQUISITE: Get fresh token
###############################################

### Step 1: Login as ADMIN - copy token from response
POST http://localhost:8081/api/auth/login
Content-Type: application/json

{
  "email": "admin@example.com",
  "password": "adminpass"
}

###############################################
# Replace ADMIN_TOKEN below with token above
###############################################

###############################################
# SETUP: Seed payment audit events in MongoDB
# S5-F11 reads from payment_audit_trail.
# Events are written by Observer when payments
# are created/refunded/failed.
# We seed by creating payments and triggering
# write operations that fire the Observer.
###############################################

### Setup 1: Create COMPLETED CREDIT_CARD payment (April)
### Observer should write CREATED event to MongoDB
POST http://localhost:8085/api/payments
Content-Type: application/json
Authorization: Bearer eyJhbGciOiJIUzI1NiJ9.eyJzdWIiOiJhZG1pbkBleGFtcGxlLmNvbSIsInVpZCI6MSwicm9sZSI6IkFETUlOIiwiaWF0IjoxNzc3OTgyMDI3LCJleHAiOjE3NzgwNjg0Mjd9.Brvd6EoneYmDnggns-cGqfpkZcjXSwMDOSFnpl9jaxc

{
  "rideId": 201,
  "userId": 1,
  "amount": 100.0,
  "method": "CREDIT_CARD",
  "status": "COMPLETED",
  "createdAt": "2026-04-05T10:00:00"
}

###

