### ─────────────────────────────────────────────────────────────
### S5-EVENTS — RabbitMQ consumers are triggered indirectly.
### You cannot call them via HTTP. Instead, test the OUTCOMES
### by first setting up data, then checking results after the
### event fires. See RabbitMQ section at the bottom for what
### to observe in the management UI.
### ─────────────────────────────────────────────────────────────

### ─────────────────────────────────────────────────────────────
### S5-F4 — Process Payment for Ride
### ─────────────────────────────────────────────────────────────

### [F4-1] SETUP — Create a ride in PAYMENT_PENDING status
### Run this directly against ride-service (not through gateway yet)
### This simulates what the saga would have done
POST http://localhost:8083/api/rides
Content-Type: application/json

{
  "userId": 1,
  "driverId": 5,
  "status": "PAYMENT_PENDING",
  "fare": 200.0,
  "pickupLatitude": 30.044,
  "pickupLongitude": 31.235,
  "dropoffLatitude": 30.055,
  "dropoffLongitude": 31.245
}

> {%
    client.global.set("rideId", response.body.id);
    client.log("Created ride with id: " + response.body.id);
%}

### [F4-2] SETUP — Create a PENDING payment manually for that ride
### (normally created by the ride.completed consumer)
POST http://localhost:8085/api/payments
Content-Type: application/json

{
  "rideId": {{rideId}},
  "userId": 1,
  "amount": 200.0,
  "status": "PENDING"
}

> {%
    client.global.set("pendingPaymentId", response.body.id);
    client.log("Created pending payment with id: " + response.body.id);
%}

### ─────────────────────────────────────────────────────────────
### [F4-3] HAPPY PATH — Valid method, ride is PAYMENT_PENDING
### Expected: 201, payment status = COMPLETED
### RabbitMQ: payment.completed event appears on payment.events exchange
### ─────────────────────────────────────────────────────────────
POST http://localhost:8085/api/payments/ride/{{rideId}}
Content-Type: application/json

{
  "method": "CREDIT_CARD",
  "cardLastFour": "4242"
}

> {%
    client.test("Status is 201", function() {
        client.assert(response.status === 201, "Expected 201, got " + response.status);
    });
    client.test("Payment status is COMPLETED", function() {
        client.assert(response.body.status === "COMPLETED", "Expected COMPLETED");
    });
    client.test("Transaction details contain surgeFee", function() {
        client.assert(response.body.transactionDetails.surgeFee !== undefined, "surgeFee missing");
    });
    client.test("cardLastFour stored", function() {
        client.assert(response.body.transactionDetails.cardLastFour === "4242", "cardLastFour mismatch");
    });
%}

### ─────────────────────────────────────────────────────────────
### [F4-4] WRONG RIDE STATUS — Ride is ACCEPTED not PAYMENT_PENDING
### Expected: 400 "Ride is not awaiting payment"
### RabbitMQ: nothing published
### ─────────────────────────────────────────────────────────────

### First create a ride with status ACCEPTED
POST http://localhost:8083/api/rides
Content-Type: application/json

{
  "userId": 1,
  "driverId": 5,
  "status": "ACCEPTED",
  "fare": 150.0,
  "pickupLatitude": 30.044,
  "pickupLongitude": 31.235,
  "dropoffLatitude": 30.055,
  "dropoffLongitude": 31.245
}

> {%
    client.global.set("acceptedRideId", response.body.id);
%}

### Now try to pay for it
POST http://localhost:8085/api/payments/ride/{{acceptedRideId}}
Content-Type: application/json

{
  "method": "CREDIT_CARD",
  "cardLastFour": "1234"
}

> {%
    client.test("Status is 400", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
    client.test("Error message mentions awaiting payment", function() {
        client.assert(
            response.body.message.includes("not awaiting payment"),
            "Wrong error: " + response.body.message
        );
    });
%}

### ─────────────────────────────────────────────────────────────
### [F4-5] NO LOCAL PENDING PAYMENT ROW
### Ride is PAYMENT_PENDING but no Payment row exists locally
### Expected: 400 "No pending payment for this ride"
### ─────────────────────────────────────────────────────────────

### Create ride with PAYMENT_PENDING but do NOT create a payment row
POST http://localhost:8083/api/rides
Content-Type: application/json

{
  "userId": 2,
  "driverId": 6,
  "status": "PAYMENT_PENDING",
  "fare": 100.0,
  "pickupLatitude": 30.044,
  "pickupLongitude": 31.235,
  "dropoffLatitude": 30.055,
  "dropoffLongitude": 31.245
}

> {%
    client.global.set("noPendingRideId", response.body.id);
%}
###
POST http://localhost:8085/api/payments/ride/{{noPendingRideId}}
Content-Type: application/json

{
  "method": "CREDIT_CARD",
  "cardLastFour": "9999"
}

> {%
  client.test("Status is 400", function() {
    client.assert(response.status === 400, "Expected 400, got " + response.status);
  });
  client.test("Error message mentions no pending payment", function() {
    client.assert(
      response.body.message.includes("No pending payment"),
      "Wrong error: " + response.body.message
    );
  });
%}

### ─────────────────────────────────────────────────────────────
### [F4-6] UNSUPPORTED METHOD — triggers payment.failed
### Expected: 400, payment row status = FAILED
### RabbitMQ: payment.failed published → compensation cascade begins
###           ride-service consumer sets ride = PAYMENT_FAILED
###           ride-service then publishes ride.cancelled(reason=payment_failed)
###           payment-service consumer then refunds → payment.refunded
###           ride-service sets ride = REFUNDED
### ─────────────────────────────────────────────────────────────

### Setup fresh ride + pending payment first (repeat F4-1 and F4-2 with new data)
POST http://localhost:8083/api/rides
Content-Type: application/json

{
  "userId": 3,
  "driverId": 7,
  "status": "PAYMENT_PENDING",
  "fare": 180.0,
  "pickupLatitude": 30.044,
  "pickupLongitude": 31.235,
  "dropoffLatitude": 30.055,
  "dropoffLongitude": 31.245
}

> {%
    client.global.set("failRideId", response.body.id);
%}
###
POST http://localhost:8085/api/payments
Content-Type: application/json

{
  "rideId": {{failRideId}},
  "userId": 3,
  "amount": 180.0,
  "status": "PENDING"
}

### Now trigger the failure
POST http://localhost:8085/api/payments/ride/{{failRideId}}
Content-Type: application/json

{
  "method": "BITCOIN",
  "cardLastFour": null
}

> {%
    client.test("Status is 400", function() {
        client.assert(response.status === 400, "Expected 400, got " + response.status);
    });
    client.test("Error message mentions invalid method", function() {
        client.assert(
            response.body.message.toLowerCase().includes("invalid") ||
            response.body.message.toLowerCase().includes("method"),
            "Wrong error: " + response.body.message
        );
    });
%}

### [F4-6 VERIFY] Wait ~2 seconds then check the ride reached REFUNDED
### Poll this until status = REFUNDED (saga cascade takes a moment)
GET http://localhost:8083/api/rides/{{failRideId}}

> {%
    client.test("Ride eventually reaches REFUNDED", function() {
        client.assert(
            response.body.status === "REFUNDED" || response.body.status === "PAYMENT_FAILED",
            "Ride status: " + response.body.status
        );
    });
%}

### ─────────────────────────────────────────────────────────────
### [F4-7] RIDE NOT FOUND — Feign returns 404
### Expected: 404
