### ─────────────────────────────────────────────────────────────
POST http://localhost:8085/api/payments/ride/999999
Content-Type: application/json

{
  "method": "CREDIT_CARD",
  "cardLastFour": "1111"
}

> {%
    client.test("Status is 404", function() {
        client.assert(response.status === 404, "Expected 404, got " + response.status);
    });
%}

### ─────────────────────────────────────────────────────────────
### S5-F10 — Vehicle Type Revenue Breakdown
### ─────────────────────────────────────────────────────────────

### [F10-1] SETUP — Make sure drivers exist in driver-service
### D1 = SEDAN, D2 = SUV, D3 = SEDAN
POST http://localhost:8082/api/drivers
Content-Type: application/json

{
  "name": "Driver SEDAN One",
  "phone": "01000000001",
  "status": "AVAILABLE",
  "vehicleDetails": {
    "vehicleType": "SEDAN",
    "model": "Toyota Camry",
    "plate": "AAA-001"
  }
}

> {%
    client.global.set("driverSedanOneId", response.body.id);
%}
###
POST http://localhost:8082/api/drivers
Content-Type: application/json

{
  "name": "Driver SUV One",
  "phone": "01000000002",
  "status": "AVAILABLE",
  "vehicleDetails": {
    "vehicleType": "SUV",
    "model": "Honda CRV",
    "plate": "BBB-002"
  }
}

> {%
  client.global.set("driverSuvId", response.body.id);
%}

### [F10-2] SETUP — Create COMPLETED rides for those drivers
POST http://localhost:8083/api/rides
Content-Type: application/json

{
  "userId": 1,
  "driverId": {{driverSedanOneId}},
  "status": "COMPLETED",
  "fare": 100.0,
  "pickupLatitude": 30.0,
  "pickupLongitude": 31.0,
  "dropoffLatitude": 30.1,
  "dropoffLongitude": 31.1
}

> {%
    client.global.set("sedanRide1", response.body.id);
%}

###
POST http://localhost:8083/api/rides
Content-Type: application/json

{
  "userId": 2,
  "driverId": {{driverSuvId}},
  "status": "COMPLETED",
  "fare": 200.0,
  "pickupLatitude": 30.0,
  "pickupLongitude": 31.0,
  "dropoffLatitude": 30.1,
  "dropoffLongitude": 31.1
}

> {%
  client.global.set("suvRide1", response.body.id);
%}

### [F10-3] SETUP — Create COMPLETED payments with surgeFee in transactionDetails
POST http://localhost:8085/api/payments
Content-Type: application/json

{
  "rideId": {{sedanRide1}},
  "userId": 1,
  "amount": 100.0,
  "status": "COMPLETED",
  "transactionDetails": {
    "surgeFee": 15.0,
    "gatewayResponse": "APPROVED"
  }
}
###
POST http://localhost:8085/api/payments
Content-Type: application/json

{
  "rideId": {{suvRide1}},
  "userId": 2,
  "amount": 200.0,
  "status": "COMPLETED",
  "transactionDetails": {
    "surgeFee": 30.0,
    "gatewayResponse": "APPROVED"
  }
}

### ─────────────────────────────────────────────────────────────
### [F10-4] HAPPY PATH — Revenue grouped by vehicle type
### Expected: 200, SEDAN and SUV entries with correct totals
### RabbitMQ: nothing — this is a read-only endpoint
### ─────────────────────────────────────────────────────────────
GET http://localhost:8085/api/payments/analytics/vehicle-type?startDate=2026-01-01&endDate=2026-12-31

> {%
    client.test("Status is 200", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Returns array", function() {
        client.assert(Array.isArray(response.body), "Expected array");
    });
    client.test("Contains SEDAN entry", function() {
        const sedan = response.body.find(e => e.vehicleType === "SEDAN");
        client.assert(sedan !== undefined, "SEDAN entry missing");
        client.assert(sedan.totalRevenue === 100.0, "SEDAN totalRevenue wrong: " + sedan.totalRevenue);
        client.assert(sedan.surgeFeeRevenue === 15.0, "SEDAN surgeFee wrong: " + sedan.surgeFeeRevenue);
        client.assert(sedan.baseFareRevenue === 85.0, "SEDAN baseFare wrong: " + sedan.baseFareRevenue);
    });
    client.test("Contains SUV entry", function() {
        const suv = response.body.find(e => e.vehicleType === "SUV");
        client.assert(suv !== undefined, "SUV entry missing");
        client.assert(suv.totalRevenue === 200.0, "SUV totalRevenue wrong: " + suv.totalRevenue);
    });
%}

### ─────────────────────────────────────────────────────────────
### [F10-5] RIDE NOT FOUND — one rideId returns 404 from ride-service
### Expected: 200 with remaining results, broken ride skipped gracefully
### ─────────────────────────────────────────────────────────────

### Insert a payment pointing to a non-existent ride
POST http://localhost:8085/api/payments
Content-Type: application/json

{
  "rideId": 999999,
  "userId": 1,
  "amount": 500.0,
  "status": "COMPLETED",
  "transactionDetails": {
    "surgeFee": 75.0
  }
}

### Run analytics again — 999999 should be skipped, real entries still returned
GET http://localhost:8085/api/payments/analytics/vehicle-type?startDate=2026-01-01&endDate=2026-12-31

> {%
    client.test("Status is 200 even with bad rideId", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
    client.test("Still returns vehicle type data", function() {
        client.assert(response.body.length >= 1, "Expected at least one entry");
    });
%}

### ─────────────────────────────────────────────────────────────
### S5-EVENTS — Testing consumer outcomes via HTTP verification
### You trigger events via ride-service actions, then verify
### the payment-service side effects via GET calls here.
### ─────────────────────────────────────────────────────────────

### [EVENTS-1] SETUP — Trigger a ride.completed event by completing a ride
### This causes ride-service to publish ride.completed →
### payment-service consumer creates a PENDING payment + publishes payment.initiated
PUT http://localhost:8083/api/rides/{{rideId}}/complete

> {%
    client.test("Ride completion accepted", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [EVENTS-1 VERIFY] Wait ~1s then check payment was auto-created as PENDING
### Poll GET /api/payments/search?rideId= if you have that, or check all payments
GET http://localhost:8085/api/payments

> {%
    client.test("A PENDING payment was created by the consumer", function() {
        const pending = response.body.filter(
            p => p.rideId == client.global.get("rideId") && p.status === "PENDING"
        );
        client.assert(pending.length === 1, "Expected 1 PENDING payment, found: " + pending.length);
    });
%}

### [EVENTS-2] IDEMPOTENCY — Trigger ride.completed again for the same ride
### Expected: consumer no-ops, still only 1 PENDING payment
PUT http://localhost:8083/api/rides/{{rideId}}/complete

GET http://localhost:8085/api/payments

> {%
    client.test("Still only 1 payment after duplicate event", function() {
        const payments = response.body.filter(
            p => p.rideId == client.global.get("rideId")
        );
        client.assert(payments.length === 1, "Expected 1, found: " + payments.length);
    });
%}

### [EVENTS-3] SETUP — Trigger ride.cancelled to test refund consumer
### This causes ride-service to publish ride.cancelled →
### payment-service consumer finds the PENDING payment, refunds it,
### publishes payment.refunded
PUT http://localhost:8083/api/rides/{{rideId}}/cancel

> {%
    client.test("Cancellation accepted", function() {
        client.assert(response.status === 200, "Expected 200, got " + response.status);
    });
%}

### [EVENTS-3 VERIFY] Wait ~1s then check the payment was refunded
GET http://localhost:8085/api/payments

> {%
    client.test("Payment was refunded by the consumer", function() {
        const refunded = response.body.filter(
            p => p.rideId == client.global.get("rideId") && p.status === "REFUNDED"
        );
        client.assert(refunded.length === 1,
            "Expected 1 REFUNDED payment, found: " + refunded.length);
    });
%}