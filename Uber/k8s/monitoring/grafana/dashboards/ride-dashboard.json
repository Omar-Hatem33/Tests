{
  "title": "Ride Service Dashboard",
  "uid": "ride-service-dash",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["ride-service", "uber"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Ride Service Error Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"ride-service\"} |= \"ERROR\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Saga State Transitions",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"ride-service\"} |~ \"PAYMENT_PENDING|PAID|PAYMENT_FAILED|REFUNDED|ride.completed|ride.cancelled\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "RabbitMQ Event Audit (by routingKey)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (routingKey) (count_over_time({service=\"ride-service\"} | json | routingKey =~ \".+\" [1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Ride Service HTTP Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_server_requests_seconds_count{job=\"ride-service\"}[5m])",
          "legendFormat": "{{uri}} {{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Ride Service HTTP Latency Percentiles (P50/P95/P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"ride-service\"}[5m]))",
          "legendFormat": "P99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"ride-service\"}[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"ride-service\"}[5m]))",
          "legendFormat": "P50",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Ride Service JVM Heap Memory",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_used_bytes{job=\"ride-service\", area=\"heap\"}",
          "legendFormat": "Heap Used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "jvm_memory_max_bytes{job=\"ride-service\", area=\"heap\"}",
          "legendFormat": "Heap Max",
          "refId": "B"
        }
      ]
    }
  ]
}
