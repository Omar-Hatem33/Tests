{
  "title": "Payment Service Dashboard",
  "uid": "payment-service-dash",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "tags": ["payment-service", "uber"],
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Payment Error Rate",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({service=\"payment-service\", level=\"ERROR\"}[1m]))",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Feign Call Outcomes",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"payment-service\"} |~ \"Feign|RideServiceClient|UserServiceClient|DriverServiceClient\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Slow Operations",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "options": { "dedupStrategy": "none", "enableLogDetails": true, "showTime": true, "sortOrder": "Descending" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{service=\"payment-service\"} |~ \"Slow|elapsed=[0-9]{4,}\"",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Payment HTTP Request Rate",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(http_server_requests_seconds_count{job=\"payment-service\"}[5m])",
          "legendFormat": "{{uri}} {{method}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Payment HTTP Latency Percentiles (P50/P95/P99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[5m]))",
          "legendFormat": "P99",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[5m]))",
          "legendFormat": "P95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{job=\"payment-service\"}[5m]))",
          "legendFormat": "P50",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Payment DB Connection Pool (HikariCP)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_active{job=\"payment-service\"}",
          "legendFormat": "Active",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_max{job=\"payment-service\"}",
          "legendFormat": "Max",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending{job=\"payment-service\"}",
          "legendFormat": "Pending",
          "refId": "C"
        }
      ]
    }
  ]
}
